model RentalOrder {
    id         String       @id @default(uuid())
    customerId String
    customer   User         @relation(fields: [customerId], references: [id], onDelete: Restrict)
    gearItemId String
    gearItem   GearItem     @relation(fields: [gearItemId], references: [id], onDelete: Restrict)
    startDate  DateTime
    endDate    DateTime
    quantity   Int          @default(1)
    totalPrice Decimal
    status     RentalStatus @default(PLACED)
    createdAt  DateTime     @default(now())
    updatedAt  DateTime     @updatedAt

    payment Payment?
    review  Review?

    @@index([customerId])
    @@index([gearItemId])
    @@index([status])
    @@map("rentalOrders")
}